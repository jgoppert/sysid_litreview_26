# Local LaTeX build products. Keep source files, figures, bibliography, and the
# CLI tracked so this directory can be uploaded to Overleaf cleanly.
/*.acn
/*.acr
/*.alg
/*.aux
/*.bbl
/*.bcf
/*.blg
/*.dvi
/*.fdb_latexmk
/*.fls
/*.glg
/*.glo
/*.gls
/*.idx
/*.ilg
/*.ind
/*.lof
/*.log
/*.lot
/*.out
/*.pdf
/*.ps
/*.run.xml
/*.synctex.gz
/*.toc
/*.w18

# Generated by the svg package/Inkscape when compiling \includesvg figures.
/fig/*_svg-tex.pdf
/fig/*_svg-tex.pdf_tex
/svg-inkscape/

# Local export artifact from ./paper.py package.
/*.zip
